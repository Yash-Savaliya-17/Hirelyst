# MinIO Configuration for Backend (.env)
# Set this to true to use MinIO instead of AWS S3
USE_MINIO=true

# MinIO Settings
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_NAME=preparcbucket
MINIO_REGION=us-east-1

# AWS S3 Settings (keep these for fallback or if USE_MINIO=false)
# AWS_S3_REGION=your-aws-region
# AWS_S3_ACCESS_KEY_ID=your-aws-access-key
# AWS_S3_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_S3_BUCKET_NAME=your-aws-bucket-name

# Other existing environment variables...
# DATABASE_URL=your-database-url
# JWT_SECRET=your-jwt-secret
# etc...