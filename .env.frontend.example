# MinIO Configuration for Frontend (.env)
# Set this to true to use MinIO instead of AWS S3
VITE_USE_MINIO=true

# MinIO Settings
VITE_MINIO_ENDPOINT=http://localhost:9000
VITE_MINIO_ACCESS_KEY=minioadmin
VITE_MINIO_SECRET_KEY=minioadmin123
VITE_MINIO_BUCKET_NAME=preparcbucket
VITE_MINIO_REGION=us-east-1

# AWS S3 Settings (keep these for fallback or if VITE_USE_MINIO=false)
# VITE_PUBLIC_S3_BUCKET_NAME=your-aws-bucket-name
# VITE_PUBLIC_S3_REGION=your-aws-region
# VITE_PUBLIC_S3_ACCESS_KEY_ID=your-aws-access-key
# VITE_PUBLIC_S3_SECRET_ACCESS_KEY=your-aws-secret-key

# Other existing environment variables...
# VITE_API_BASE_URL=http://localhost:3000
# etc...